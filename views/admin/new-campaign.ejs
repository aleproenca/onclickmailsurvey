<%- include('../partials/header', { title: 'Nova campanha' }) %>
<section class="card">
  <h1>Criar nova campanha</h1>
  <form method="post" action="/admin/campaigns" class="form-grid">
    <label>
      Título da campanha
      <input name="title" required maxlength="140" />
    </label>
    <label>
      Pergunta
      <textarea name="question" required rows="3" maxlength="300"></textarea>
    </label>
    <button class="btn" type="submit">Criar campanha</button>
  </form>
</section>
<%- include('../partials/footer') %>
